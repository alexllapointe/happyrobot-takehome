# Server-side only — never expose to the browser. The Next.js route handlers
# in app/api/* read these and proxy to the Express API.
API_BASE_URL=http://localhost:3000
API_KEY=replace_with_the_same_key_used_by_the_express_api

# Public — used by the browser ONLY to open a Supabase realtime channel.
# The dashboard never reads row data from Supabase directly; the realtime
# subscription only fires invalidation signals that trigger a refetch
# through /api/*. Anon key + RLS gates access.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
