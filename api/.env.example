PORT=3000
API_KEY=replace_with_openssl_rand_hex_32
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
FMCSA_WEBKEY=your_fmcsa_webkey

# Comma-separated MC numbers that should pass eligibility regardless of
# what FMCSA reports. Useful when a known-good MC has lapsed authority but
# you still want to demo the flow with it. The carrier name comes from
# FMCSA when present; otherwise we synthesize a generic "Demo Carrier".
# Leave blank in production.
DEMO_MC_OVERRIDES=

# Shared secret for the inbound HappyRobot webhook at
# POST /webhooks/happyrobot. When set, the route requires the same value in
# one of: `x-webhook-secret`, `x-happyrobot-signature`, or
# `Authorization: Bearer <secret>`. Leave blank only for local dev —
# production should always set this.
HAPPY_ROBOT_WEBHOOK_SECRET=
